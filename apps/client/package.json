{
  "name": "@contourlab/client",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:sys": "PLAYWRIGHT_JUNIT_OUTPUT_NAME=test-results/e2e-sys-junit.xml playwright test --project=sys",
    "test:e2e:crs": "PLAYWRIGHT_JUNIT_OUTPUT_NAME=test-results/e2e-crs-junit.xml playwright test --project=crs",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cornerstonejs/codec-charls": "^1.2.3",
    "@cornerstonejs/codec-libjpeg-turbo-8bit": "^1.2.2",
    "@cornerstonejs/codec-openjpeg": "^1.3.0",
    "@cornerstonejs/codec-openjph": "^2.4.7",
    "@cornerstonejs/core": "^4.21.0",
    "@cornerstonejs/dicom-image-loader": "^4.21.0",
    "@cornerstonejs/tools": "^4.21.0",
    "@kitware/vtk.js": "^34.15.1",
    "dcmjs": "^0.50.1",
    "dicom-parser": "^1.8.21",
    "immer": "^11.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "typescript-eslint": "latest",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
