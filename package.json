{
  "name": "webtps",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @webtps/client dev",
    "api": "cd apps/api && dotnet run --launch-profile http",
    "repo:up": "docker compose up -d dicom-repo",
    "repo:down": "docker compose down",
    "repo:logs": "docker compose logs -f dicom-repo",
    "local:setup": "node scripts/dev/bootstrap.mjs",
    "local:up": "node scripts/dev/up.mjs",
    "local:doctor": "node scripts/dev/doctor.mjs",
    "local:down": "pnpm repo:down",
    "automation:stage1:plan-spec": "node scripts/automation/stage1-plan-spec.mjs",
    "automation:stage2:implementation": "node scripts/automation/stage2-implementation-pr.mjs",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
